<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Everardo Porras — AI Solutions Architect</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #0D1117;
      --bg-surface:  #161B22;
      --bg-deep:     #1C2128;
      --accent:      #E6A817;
      --text:        #E6EDF3;
      --muted:       #7D8590;
      --border:      #30363D;
      --pad:         clamp(24px, 8vw, 120px);
      --maxw:        1100px;
      --radius:      8px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 100;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 var(--pad);
      background: rgba(13,17,23,0.92);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.08em;
      color: var(--text);
    }
    .nav-logo em { font-style: normal; color: var(--accent); }

    .nav-links { display: flex; gap: clamp(16px,3vw,32px); list-style: none; }
    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 13px;
      transition: color 0.2s;
    }
    .nav-links a:hover,
    .nav-links a.active { color: var(--text); }

    /* ─── SECTION WRAPPER ─── */
    .wrap {
      max-width: var(--maxw);
      margin: 0 auto;
      padding: 0 var(--pad);
    }

    /* ─── HERO ─── */
    #hero {
      min-height: 100vh;
      padding: 0 var(--pad);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 120px;
      padding-bottom: 80px;
      max-width: var(--maxw);
      margin: 0 auto;
    }

    .hero-line {
      width: 0;
      height: 3px;
      background: var(--accent);
      border-radius: 2px;
      margin-bottom: 36px;
      animation: grow 0.8s cubic-bezier(.4,0,.2,1) forwards;
    }
    @keyframes grow { to { width: 64px; } }

    .eyebrow {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 22px;
      opacity: 0;
      animation: up 0.5s ease forwards 0.2s;
    }

    .h-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(38px, 6vw, 72px);
      font-weight: 700;
      line-height: 1.1;
    }
    .h-white  { opacity: 0; animation: up 0.5s ease forwards 0.35s; }
    .h-muted  { color: var(--muted); opacity: 0; animation: up 0.5s ease forwards 0.5s; }
    .h-accent { color: var(--accent); min-height: 1.1em; }

    .cursor {
      display: inline-block;
      width: 3px;
      height: 0.8em;
      background: var(--accent);
      vertical-align: middle;
      margin-left: 3px;
      animation: blink 1s step-end infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }

    .hero-sub {
      max-width: 520px;
      font-size: 16px;
      color: var(--muted);
      line-height: 1.85;
      margin-top: 32px;
      opacity: 0;
      animation: up 0.5s ease forwards 0.65s;
    }

    .hero-ctas {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 48px;
      opacity: 0;
      animation: up 0.5s ease forwards 0.85s;
    }

    @keyframes up {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── BUTTONS ─── */
    .btn-p {
      background: var(--accent);
      color: #0D1117;
      padding: 12px 28px;
      border-radius: 6px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .btn-p:hover { opacity: 0.88; }

    .btn-s {
      border: 1px solid var(--border);
      color: var(--text);
      padding: 12px 28px;
      border-radius: 6px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 500;
      font-size: 13px;
      text-decoration: none;
      transition: border-color 0.2s;
    }
    .btn-s:hover { border-color: var(--muted); }

    /* ─── SECTION CHROME ─── */
    .section-block {
      border-top: 1px solid var(--border);
      padding: 80px 0;
    }

    .label {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }

    .s-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(26px, 3vw, 38px);
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 40px;
    }
    .s-title .m { color: var(--muted); }

    /* ─── ABOUT ─── */
    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 48px;
    }

    .about-copy p {
      color: var(--muted);
      line-height: 1.85;
      font-size: 15px;
      margin-bottom: 16px;
    }
    .about-copy h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(24px,3vw,36px);
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 24px;
    }
    .about-copy h2 em { font-style: normal; color: var(--accent); }

    .stats { display: flex; flex-direction: column; gap: 12px; }

    .stat {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 22px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .stat-l { font-size: 13px; color: var(--muted); }
    .stat-v {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 28px;
      font-weight: 700;
      color: var(--accent);
    }

    /* ─── PROJECTS ─── */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 18px;
      margin-bottom: 18px;
    }

    .card {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      cursor: pointer;
      transition: border-color 0.2s, transform 0.2s;
    }
    .card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .card.open  { border-color: var(--accent); border-left: 3px solid var(--accent); }

    .card-tag {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }
    .card-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .card-desc { font-size: 14px; color: var(--muted); line-height: 1.75; }

    .chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
    .chip {
      background: var(--bg-deep);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 3px 10px;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 11px;
      color: var(--muted);
    }

    .insight {
      display: none;
      border-left: 2px solid var(--accent);
      padding-left: 16px;
      margin-top: 18px;
      font-size: 13px;
      color: var(--muted);
      font-style: italic;
      line-height: 1.75;
    }

    /* ASIS card */
    .asis {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .asis:hover { border-color: var(--accent); }
    .asis.open  { border-color: var(--accent); border-left: 3px solid var(--accent); }

    .asis-inner {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
    }

    .asis-quote {
      background: var(--bg);
      border: 1px solid var(--accent);
      border-radius: 6px;
      padding: 22px 26px;
      font-size: 14px;
      color: var(--text);
      line-height: 1.85;
      font-style: italic;
    }

    .hint {
      text-align: center;
      font-size: 12px;
      color: var(--muted);
      margin-top: 20px;
      letter-spacing: 0.02em;
    }

    /* ─── STACK ─── */
    .stack-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
    }
    .stack-block {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px;
    }
    .stack-cat {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
    }
    .stack-item { font-size: 14px; color: var(--text); line-height: 2.1; }

    /* ─── CONTACT ─── */
    .contact-body {
      color: var(--muted);
      font-size: 15px;
      line-height: 1.8;
      max-width: 480px;
      margin-top: 0;
      margin-bottom: 44px;
    }
    .contact-links { display: flex; flex-direction: column; gap: 22px; }
    .contact-link {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      color: var(--text);
      text-decoration: none;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 16px;
      transition: color 0.2s;
    }
    .contact-link:hover { color: var(--accent); }
    .arrow { color: var(--accent); font-family: monospace; font-size: 18px; }

    /* ─── FOOTER ─── */
    footer {
      border-top: 1px solid var(--border);
      padding: 28px var(--pad);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }
    .f-copy { font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--muted); }
    .f-tag  { font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--muted); }
    .f-tag em { font-style: normal; color: var(--accent); }

    /* ─── MOBILE ─── */
    @media (max-width: 640px) {
      .nav-links { display: none; }
    }
  </style>
</head>
